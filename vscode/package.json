{
    "name": "lugo-vscode",
    "displayName": "Lugo - Lua LSP",
    "description": " A high-performance, zero-allocation Lua 5.4 parser and Language Server (LSP).",
    "publisher": "coalaura",
    "icon": "logo.png",
    "version": "0.1.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/coalaura/lugo.git"
    },
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Programming Languages",
        "Linters"
    ],
    "activationEvents": [
        "onLanguage:lua",
        "workspaceContains:**/*.lua"
    ],
    "main": "./extension.js",
    "scripts": {
        "build": "esbuild ./extension.js --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --target=node18"
    },
    "contributes": {
        "commands": [
            {
                "command": "lugo.reindex",
                "title": "Lugo: Re-index Workspace"
            }
        ],
        "configuration": {
            "type": "object",
            "title": "Lugo LSP",
            "properties": {
                "lugo.ignoreGlobs": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [
                        "fxmanifest.lua",
                        "__resource.lua"
                    ],
                    "description": "List of globs/files to ignore during indexing. Inherits VS Code's files.exclude automatically."
                },
                "lugo.libraryPaths": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [],
                    "description": "List of absolute paths to external Lua libraries to index."
                },
                "lugo.knownGlobals": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [
                        "source",
                        "Citizen"
                    ],
                    "description": "List of global variables to ignore when reporting undefined globals."
                },
                "lugo.diagnostics.undefinedGlobals": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable diagnostics for undefined global variables."
                },
                "lugo.diagnostics.unusedVariables": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable diagnostics for unused local variables."
                },
                "lugo.diagnostics.shadowing": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable diagnostics when a local variable shadows a global or outer local."
                }
            }
        }
    },
    "dependencies": {
        "vscode-languageclient": "^9.0.1"
    },
    "devDependencies": {
        "@types/vscode": "^1.80.0",
        "esbuild": "^0.20.0"
    }
}