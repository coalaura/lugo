{
    "name": "lugo-vscode",
    "displayName": "Lugo - Lua LSP",
    "description": " A high-performance, zero-allocation Lua 5.4 parser and Language Server (LSP).",
    "publisher": "coalaura",
    "icon": "logo.png",
    "version": "0.2.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/coalaura/lugo.git"
    },
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Programming Languages",
        "Linters"
    ],
    "activationEvents": [
        "onLanguage:lua",
        "workspaceContains:**/*.lua"
    ],
    "main": "./extension.js",
    "scripts": {
        "build": "esbuild ./extension.js --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --target=node18"
    },
    "contributes": {
        "commands": [
            {
                "command": "lugo.reindex",
                "title": "Lugo: Re-index Workspace"
            }
        ],
        "configuration": {
            "type": "object",
            "title": "Lugo LSP",
            "properties": {
                "lugo.workspace.libraryPaths": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [],
                    "description": "List of absolute paths to external Lua libraries to index.",
                    "order": 1
                },
                "lugo.workspace.ignoreGlobs": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [],
                    "description": "List of globs/files to ignore during indexing. Inherits VS Code's files.exclude automatically.",
                    "order": 2
                },
                "lugo.environment.knownGlobals": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [],
                    "description": "List of global variables to ignore when reporting undefined globals.",
                    "order": 3
                },
                "lugo.diagnostics.undefinedGlobals": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable diagnostics for undefined global variables.",
                    "order": 4
                },
                "lugo.diagnostics.unusedVariables": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable diagnostics for unused local variables.",
                    "order": 5
                },
                "lugo.diagnostics.shadowing": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable diagnostics when a local variable shadows a global or outer local.",
                    "order": 6
                },
                "lugo.diagnostics.unreachableCode": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable diagnostics for unreachable code (e.g. after a return or break).",
                    "order": 7
                },
                "lugo.diagnostics.ambiguousReturns": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable diagnostics for ambiguous returns where an expression on the next line is accidentally returned.",
                    "order": 8
                },
                "lugo.inlayHints.parameterNames": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable inline parameter name hints for function and method calls.",
                    "order": 9
                }
            }
        }
    },
    "dependencies": {
        "vscode-languageclient": "^9.0.1"
    },
    "devDependencies": {
        "@types/vscode": "^1.80.0",
        "esbuild": "^0.20.0"
    }
}