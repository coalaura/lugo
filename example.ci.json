{
	"workspaceFolders": [
		"."
	],
	"settings": {
		"libraryPaths": [],
		"ignoreGlobs": [
			"**/node_modules/**",
			"**/.git/**",
			"**/dist/**"
		],
		"knownGlobals": [
			
		],
		"bannedSymbols": {},
		"maxFileSizeMB": 4,
		"parserMaxErrors": 50,
		"diagUndefinedGlobals": true,
